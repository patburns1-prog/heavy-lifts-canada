---
import Layout from '../layouts/Layout.astro';
import { wheelChockProducts } from '../data/wheelChockProducts';
---
<Layout title="Wheel Chocks | Heavy Lifts Canada" description="Verified ESCO wheel chock models for heavy-duty shop, fleet, field, mining, and industrial applications with quote-first support from Heavy Lifts Canada.">
  <section class="hero">
    <div class="hero-grid">
      <div>
        <p class="eyebrow">Verified ESCO category</p>
        <h1>Wheel Chocks for Heavy-Duty Vehicle Positioning</h1>
        <p>Start with tire diameter, GVW, and environment, then move into the RFQ flow with the right context already in place.</p>
        <div class="actions">
          <a class="btn btn-primary" href="/request-a-quote?category=wheel-chocks">Request a Quote</a>
          <a class="btn btn-secondary" href="#models">View Wheel Chock Models</a>
        </div>
      </div>
      <aside class="proof-panel">
        <h3>How to Choose</h3>
        <ul class="proof-list">
          <li>Match tire diameter</li>
          <li>Check GVW guide range</li>
          <li>Consider terrain and surface</li>
          <li>Choose material for the environment</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section" id="models">
    <h2>Verified Wheel Chock Models</h2>
    <p class="lead">Click any card for a cleaner detail view, or quote directly from the model card.</p>
    <div class="grid">
      {wheelChockProducts.map((product) => (
        <div class="card product-card">
          <a class="product-card-link" href={`/wheel-chocks/${product.model}`}>
            <img class="product-card-image" src={product.image} alt={`Wheel chock model ${product.model}`} />
            <div class="product-card-body">
              <p class="product-model">Model {product.model}</p>
              <h3>{product.title}</h3>
              <p>{product.summary}</p>
              <p class="product-best-for"><strong>Best for:</strong> {product.bestFor}</p>
              <ul class="spec-list">
                <li><strong>GVW Guide:</strong> {product.gvwCapacity}</li>
                <li><strong>Tire Size:</strong> {product.tireSize}</li>
                <li><strong>Material:</strong> {product.material}</li>
              </ul>
            </div>
          </a>
          <div class="product-card-body">
            <div class="product-actions">
              <button class="btn btn-primary add-to-quote" type="button" data-category="wheel-chocks" data-product={product.model} data-title={product.title}>Add to Quote</button>
              <a class="inline-link" href={`/wheel-chocks/${product.model}`}>View details</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>
  <script is:inline>
    const addButtons = document.querySelectorAll('.add-to-quote');
    addButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const items = JSON.parse(localStorage.getItem('quoteItems') || '[]');
        const nextItem = {
          category: button.dataset.category,
          product: button.dataset.product,
          title: button.dataset.title,
          quantity: 1,
        };
        if (!items.find((item) => item.category === nextItem.category && item.product === nextItem.product)) {
          items.push(nextItem);
          localStorage.setItem('quoteItems', JSON.stringify(items));
          window.dispatchEvent(new Event('quote-items-updated'));
        }
        button.textContent = 'Added';
      });
    });
  </script>
</Layout>
