---
import Layout from '../../layouts/Layout.astro';
import { wheelChockProducts } from '../../data/wheelChockProducts';

export function getStaticPaths() {
  return wheelChockProducts.map((product) => ({ params: { model: product.model }, props: { product } }));
}

const { product } = Astro.props;
---
<Layout title={`${product.model} | Wheel Chocks | Heavy Lifts Canada`} description={product.summary}>
  <section class="hero">
    <div class="hero-grid">
      <div>
        <p class="eyebrow">Wheel chock details</p>
        <h1>{product.title}</h1>
        <p>{product.summary}</p>
        <div class="actions">
          <a class="btn btn-primary" href={`/request-a-quote?category=wheel-chocks&product=${product.model}`}>Quote {product.model}</a>
          <a class="btn btn-secondary" href="/wheel-chocks">Back to Wheel Chocks</a>
        </div>
      </div>
      <div class="proof-panel">
        <img class="product-card-image" src={product.image} alt={`Wheel chock model ${product.model}`} />
      </div>
    </div>
  </section>
  <section class="section split">
    <div class="band">
      <h2>Verified Specs</h2>
      <ul class="spec-list">
        <li><strong>Model:</strong> {product.model}</li>
        <li><strong>Material:</strong> {product.material}</li>
        <li><strong>GVW Guide:</strong> {product.gvwCapacity}</li>
        <li><strong>Tire Size:</strong> {product.tireSize}</li>
        <li><strong>Dimensions:</strong> {product.dimensions}</li>
        <li><strong>Weight:</strong> {product.weight}</li>
      </ul>
    </div>
    <div class="band">
      <h2>Best Fit</h2>
      <p class="lead">{product.bestFor}</p>
      <p class="lead">Use this model page when you want a cleaner handoff from selection into quote request.</p>
    </div>
  </section>
  <section class="section split">
    <div class="band">
      <h2>What to send with your quote request</h2>
      <ul class="spec-list">
        <li>Vehicle or equipment type</li>
        <li>Tire diameter or tire size</li>
        <li>Gross vehicle weight</li>
        <li>Operating surface or terrain</li>
        <li>Quantity needed</li>
      </ul>
    </div>
    <div class="band band-dark">
      <h2>Need help choosing the right wheel chock?</h2>
      <p class="lead">If you are not certain which model fits the application, send tire size, GVW, and job conditions so we can narrow the best options.</p>
      <div class="actions">
        <a class="btn btn-primary" href="/wheel-chocks">Back to Wheel Chocks</a>
      </div>
    </div>
  </section>
</Layout>
