---
import Layout from '../../layouts/Layout.astro';
import { cribbingProducts } from '../../data/cribbingProducts';

export function getStaticPaths() {
  return cribbingProducts.map((product) => ({ params: { model: product.slug }, props: { product } }));
}

const { product } = Astro.props;
const relatedProducts = cribbingProducts.filter((item) => item.slug !== product.slug).slice(0, 3);
---
<Layout title={`${product.title} | Cribbing | Heavy Lifts Canada`} description={product.summary}>
  <section class="hero">
    <div class="hero-grid">
      <div>
        <p class="eyebrow">Cribbing details</p>
        <h1>{product.title}</h1>
        <p>{product.summary}</p>
        <div class="actions">
          <a class="btn btn-primary" href={`/request-a-quote?category=cribbing&product=${encodeURIComponent(product.model)}`}>Quote this family</a>
          <a class="btn btn-secondary" href="/cribbing">Back to Cribbing</a>
        </div>
      </div>
      <div class="proof-panel">
        <img class="product-card-image" src={product.image} alt={product.title} />
      </div>
    </div>
  </section>
  <section class="section split">
    <div class="band">
      <h2>Verified Specs</h2>
      <ul class="spec-list">
        <li><strong>Model:</strong> {product.model}</li>
        <li><strong>Capacity:</strong> {product.capacity}</li>
        {product.dimensions && <li><strong>Dimensions:</strong> {product.dimensions}</li>}
        {product.weight && <li><strong>Weight:</strong> {product.weight}</li>}
        {product.kitRange && <li><strong>Kit Range:</strong> {product.kitRange}</li>}
      </ul>
    </div>
    <div class="band">
      <h2>Best Fit</h2>
      <p class="lead">{product.bestFor}</p>
      <p class="lead">Use this detail page when you want a cleaner explanation before sending the RFQ.</p>
    </div>
  </section>
  <section class="section split">
    <div class="band">
      <h2>What to send with your quote request</h2>
      <ul class="spec-list">
        <li>Load or equipment type</li>
        <li>Support or stabilization need</li>
        <li>Height requirement</li>
        <li>Surface conditions</li>
        <li>Quantity or kit scope</li>
      </ul>
    </div>
    <div class="band band-dark">
      <h2>Need help choosing the right support setup?</h2>
      <p class="lead">If you are comparing cribbing families, send the job conditions and support need so we can help narrow the right direction.</p>
      <ul class="spec-list">
        <li>Call out whether the need is stabilization, support, or lifting support</li>
        <li>Include uneven-surface or field-condition details if relevant</li>
        <li>Tell us whether you need a single setup or a broader kit/system</li>
      </ul>
      <div class="actions">
        <a class="btn btn-primary" href={`/request-a-quote?category=cribbing&product=${encodeURIComponent(product.model)}`}>Quote this family</a>
        <a class="btn btn-secondary" href="/cribbing">Back to Cribbing</a>
      </div>
    </div>
  </section>

  <section class="section">
    <h2>Compare Other Support Options</h2>
    <p class="lead">If this setup is close but not the right fit, these are the next cribbing or support options to review.</p>
    <div class="path-grid">
      {relatedProducts.map((item) => (
        <div class="path-card">
          <h3>{item.title}</h3>
          <p>{item.bestFor}</p>
          <a class="inline-link" href={`/cribbing/${item.slug}`}>View this option</a>
        </div>
      ))}
      <div class="path-card">
        <h3>Need a broader support system?</h3>
        <p>If you are building a more complete stabilization or support setup, send the full job context and we can help narrow the right direction.</p>
        <a class="inline-link" href="/request-a-quote?category=cribbing">Start a cribbing RFQ</a>
      </div>
    </div>
  </section>
</Layout>
