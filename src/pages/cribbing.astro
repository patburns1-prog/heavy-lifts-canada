---
import Layout from '../layouts/Layout.astro';
import { cribbingProducts } from '../data/cribbingProducts';
---
<Layout title="Cribbing | Heavy Lifts Canada" description="Verified ESCO cribbing and support-system families for heavy-duty stabilization and support applications, with quote-first support from Heavy Lifts Canada.">
  <section class="hero">
    <div class="hero-grid">
      <div>
        <p class="eyebrow">Verified ESCO category</p>
        <h1>Cribbing for Stabilization and Support Applications</h1>
        <p>Start with load, support need, height, and surface conditions, then move into the quote flow with the right category context.</p>
        <div class="actions">
          <a class="btn btn-primary" href="/request-a-quote?category=cribbing">Request a Quote</a>
          <a class="btn btn-secondary" href="#families">View Cribbing Families</a>
        </div>
      </div>
      <aside class="proof-panel">
        <h3>How to Choose</h3>
        <ul class="proof-list">
          <li>Define the load and support need</li>
          <li>Check required height or kit range</li>
          <li>Consider ground and surface conditions</li>
          <li>Match system type to the setup</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section" id="families">
    <h2>Verified Cribbing & Support Families</h2>
    <p class="lead">Click any card to open a cleaner detail page, or quote directly from the family card.</p>
    <div class="grid">
      {cribbingProducts.map((product) => (
        <div class="card product-card">
          <a class="product-card-link" href={`/cribbing/${product.slug}`}>
            <img class="product-card-image" src={product.image} alt={product.title} />
            <div class="product-card-body">
              <p class="product-model">Model {product.model}</p>
              <h3>{product.title}</h3>
              <p>{product.summary}</p>
              <p class="product-best-for"><strong>Best for:</strong> {product.bestFor}</p>
              <ul class="spec-list">
                <li><strong>Capacity:</strong> {product.capacity}</li>
                {product.kitRange && <li><strong>Kit Range:</strong> {product.kitRange}</li>}
              </ul>
            </div>
          </a>
          <div class="product-card-body">
            <div class="product-actions">
              <button class="btn btn-primary add-to-quote" type="button" data-category="cribbing" data-product={product.model} data-title={product.title}>Add to Quote</button>
              <a class="inline-link" href={`/cribbing/${product.slug}`}>View details</a>
            </div>
            <p class="quote-state" data-category="cribbing" data-product={product.model}></p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <script type="module">
    import { bindAddToQuoteButtons } from '/src/scripts/quoteState.js';
    bindAddToQuoteButtons();
  </script>
</Layout>
