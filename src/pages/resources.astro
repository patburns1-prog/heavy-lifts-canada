---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Resources | Heavy Lifts Canada"
  description="Product references, catalog visuals, and supporting material for Mammut jacks, ESCO wheel chocks, and cribbing systems."
>
  <section class="hero">
    <div class="hero-grid">
      <div>
        <p class="eyebrow">Supporting material</p>
        <h1>Resources & Product References</h1>
        <p>
          This page gathers the current catalog references and visual support material used to build
          the review site around Mammut jacks, ESCO wheel chocks, and cribbing/support systems.
        </p>
        <div class="actions">
          <a class="btn btn-primary" href="/request-a-quote">Request a Quote</a>
          <a class="btn btn-secondary" href="/contact">Contact Heavy Lifts Canada</a>
        </div>
      </div>
      <aside class="proof-panel">
        <h3>Current Coverage</h3>
        <ul class="proof-list">
          <li>Mammut jack references</li>
          <li>Wheel chock catalog pages</li>
          <li>Cribbing and support references</li>
          <li>RFQ-oriented selection guidance</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section">
    <h2>Mammut References</h2>
    <div class="resource-grid">
      <div class="resource-card">
        <img src="/images/mammut-jacks.png" alt="Mammut jacks overview" />
        <div class="resource-card-body">
          <h3>Mammut Jacks Overview</h3>
          <p>Visual reference supporting the Mammut category and current review-build direction.</p>
        </div>
      </div>
      <div class="resource-card">
        <img src="/images/mammut-91000.png" alt="Mammut 91000 reference" />
        <div class="resource-card-body">
          <h3>Mammut 91000 Reference</h3>
          <p>Product-oriented image support for the verified Mammut model layer.</p>
        </div>
      </div>
      <div class="resource-card">
        <img src="/images/catalog/page-114.jpg" alt="Mammut catalog reference" />
        <div class="resource-card-body">
          <h3>Catalog Support</h3>
          <p>Supporting catalog page used as a source reference for Mammut content direction.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <h2>Wheel Chock References</h2>
    <div class="resource-grid">
      <div class="resource-card">
        <img src="/images/catalog/page-117.jpg" alt="Wheel chocks catalog overview" />
        <div class="resource-card-body">
          <h3>Wheel Chocks Overview</h3>
          <p>Catalog-based visual support for the verified ESCO wheel chock family now in the site.</p>
        </div>
      </div>
      <div class="resource-card">
        <img src="/images/catalog/page-118.jpg" alt="Wheel chock model guide" />
        <div class="resource-card-body">
          <h3>Wheel Chock Model Guide</h3>
          <p>Useful model-family context for review and future deeper product documentation.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <h2>Cribbing & Support References</h2>
    <div class="resource-grid">
      <div class="resource-card">
        <img src="/images/catalog/page-115.jpg" alt="Cribbing support catalog reference" />
        <div class="resource-card-body">
          <h3>Cribbing Support Section</h3>
          <p>Catalog reference supporting steel stands, support plates, and related support products.</p>
        </div>
      </div>
      <div class="resource-card">
        <img src="/images/catalog/page-116.jpg" alt="CriBLOK system reference" />
        <div class="resource-card-body">
          <h3>CriBLOK System Reference</h3>
          <p>Visual support for the CriBLOK system components and kit-based selection direction.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section cta-band">
    <div>
      <p class="eyebrow">Need something specific?</p>
      <h2>If you need a product document or help narrowing the right model, send the request.</h2>
      <p class="lead">
        The review build is already structured around quote-first selection, so a good inquiry can
        move faster than waiting for a full document library.
      </p>
    </div>
    <div class="actions">
      <a class="btn btn-primary" href="/request-a-quote">Start a Quote Request</a>
      <a class="btn btn-secondary" href="/faq">View FAQ</a>
    </div>
  </section>
</Layout>
