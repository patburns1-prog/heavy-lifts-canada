---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../data/siteConfig';
---
<Layout
  title="Heavy Lifts Canada | Heavy-Duty Lifting & Support Equipment in Fort McMurray"
  description="Heavy Lifts Canada supplies heavy-duty lifting and support equipment including Mammut jacks, ESCO wheel chocks, and cribbing. Based in Fort McMurray and shipping across Canada."
>
  <section class="hero">
    <div class="hero-grid">
      <div>
        <p class="eyebrow">Heavy-duty lifting and support equipment</p>
        <h1>Industrial Lifting & Support Equipment Backed by Practical Quote Support</h1>
        <p>
          {siteConfig.brandName} helps shops, fleets, mining operations, contractors, and industrial
          buyers source Mammut jacks, ESCO wheel chocks, cribbing, and related support equipment
          across Fort McMurray and Canada.
        </p>
        <div class="actions">
          <a class="btn btn-primary" href="/request-a-quote?path=known-model">Request a Quote</a>
          <a class="btn btn-secondary" href="/contact">Talk to Heavy Lifts Canada</a>
        </div>
        <div class="hero-stat-grid">
          <div class="hero-stat">
            <strong>3</strong>
            <span>Live product categories with active buyer paths</span>
          </div>
          <div class="hero-stat">
            <strong>Canada</strong>
            <span>Shipping support for industrial buyers across the country</span>
          </div>
          <div class="hero-stat">
            <strong>Fort McMurray</strong>
            <span>Locally rooted support with regional industrial context</span>
          </div>
          <div class="hero-stat">
            <strong>Quote-First</strong>
            <span>Product guidance that starts with the job, not just the part number</span>
          </div>
        </div>
      </div>
      <aside class="proof-panel">
        <h3>Why This Site Exists</h3>
        <ul class="proof-list">
          <li>Cut through generic catalog clutter</li>
          <li>Help buyers reach the right product faster</li>
          <li>Support industrial applications with practical guidance</li>
          <li>Give shops, fleets, and contractors a cleaner quote path</li>
          <li>Serve Fort McMurray and Canada-wide buyers with real business support</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section trust-strip">
    <div class="trust-item">
      <strong>Local Base</strong>
      <span>Fort McMurray roots with local accountability.</span>
    </div>
    <div class="trust-item">
      <strong>Canada-Wide</strong>
      <span>Structured to support buyers across Canada.</span>
    </div>
    <div class="trust-item">
      <strong>Industrial Focus</strong>
      <span>Built for heavy-duty repair, fleet, mining, and oilfield work.</span>
    </div>
    <div class="trust-item">
      <strong>Quote-First</strong>
      <span>Application-based support instead of public price clutter.</span>
    </div>
    <div class="trust-item">
      <strong>Direct Support</strong>
      <span>Phone, email, and structured RFQ paths are all available.</span>
    </div>
  </section>

  <section class="section">
    <h2>Choose Your Starting Point</h2>
    <div class="path-grid">
      <div class="path-card-minimal">
        <h3>Know the model?</h3>
        <p>Go straight to the RFQ page and send the exact model number, quantity, and application details.</p>
        <a class="inline-link" href="/request-a-quote?path=known-model">Request a Quote</a>
      </div>
      <div class="path-card-minimal">
        <h3>Know the category?</h3>
        <p>Browse jacks, wheel chocks, or cribbing if you know the type of product but need help narrowing the right fit.</p>
        <a class="inline-link" href="#categories">Browse Categories</a>
      </div>
      <div class="path-card-minimal">
        <h3>Need help choosing?</h3>
        <p>Call or email with the application details and we can work backward from the job requirements.</p>
        <a class="inline-link" href="/contact">Contact Heavy Lifts Canada</a>
      </div>
    </div>
  </section>

  <section class="section split" id="categories">
    <div class="band">
      <h2>Shop by Category</h2>
      <p class="lead">
        Start with the category that matches the job you are trying to solve, then move into the
        quote flow with the right context.
      </p>
      <div class="grid compact-grid">
        <div class="card product-card">
          <img class="product-card-image" src="/images/products/mammut-91000.jpg" alt="Mammut Jacks" />
          <div class="product-card-body">
            <p class="eyebrow">High-Capacity Lifting</p>
            <h3>Mammut Jacks</h3>
            <p>Verified Mammut model data and quote-first product flow for high-capacity lifting work.</p>
            <ul class="cue-list">
              <li>Capacity and lift-range comparison</li>
              <li>Low-profile to high-lift options</li>
              <li>Accessory and application support</li>
            </ul>
            <div class="actions">
              <a class="btn btn-primary" href="/mammut-jacks">View Mammut Jacks</a>
            </div>
          </div>
        </div>
        <div class="card product-card">
          <img class="product-card-image" src="/images/products/12594.jpg" alt="Wheel Chocks" />
          <div class="product-card-body">
            <p class="eyebrow">Wheel Restraint</p>
            <h3>Wheel Chocks</h3>
            <p>Verified ESCO wheel chock models with GVW guide ranges, tire-size guidance, and materials.</p>
            <ul class="cue-list">
              <li>GVW guide range</li>
              <li>Tire diameter fit</li>
              <li>Polyurethane and rubber options</li>
            </ul>
            <div class="actions">
              <a class="btn btn-primary" href="/wheel-chocks">View Wheel Chocks</a>
            </div>
          </div>
        </div>
        <div class="card product-card">
          <img class="product-card-image" src="/images/products/12531.jpg" alt="Cribbing" />
          <div class="product-card-body">
            <p class="eyebrow">Support & Stabilization</p>
            <h3>Cribbing</h3>
            <p>Verified ESCO cribbing families including steel stands, CriBLOK systems, kits, and support plates.</p>
            <ul class="cue-list">
              <li>Capacity and height range</li>
              <li>Support and stabilization options</li>
              <li>System and kit-based selection</li>
            </ul>
            <div class="actions">
              <a class="btn btn-primary" href="/cribbing">View Cribbing</a>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="band band-dark">
      <h2>Why Buyers Call Heavy Lifts Canada</h2>
      <p class="lead">
        We are building this business around straightforward quote support, practical product
        guidance, and a more useful buying experience for industrial customers who need the right
        equipment—not more catalog clutter.
      </p>
      <ul class="spec-list">
        <li>Locally rooted in Fort McMurray</li>
        <li>Canada-wide shipping support</li>
        <li>Industrial buyer focus</li>
        <li>Certified Full Aboriginal Member with NAABA</li>
        <li>Quote-first product support</li>
      </ul>
      <div class="actions">
        <a class="btn btn-primary" href="/request-a-quote?path=quote-process">Start Your Quote Request</a>
        <a class="btn btn-secondary" href="/contact">Talk to Heavy Lifts Canada</a>
      </div>
    </div>
  </section>

  <section class="section">
    <h2>Featured Products</h2>
    <div class="path-grid">
      <div class="path-card product-card">
        <img class="product-card-image" src="/images/products/mammut-91000.jpg" alt="Mammut 91000" />
        <div class="product-card-body">
          <p class="eyebrow">Featured Product</p>
          <h3>Mammut 91000</h3>
          <p>88/55/27 ton air hydraulic jack built for high-capacity lifting where starting clearance still matters.</p>
          <div class="product-actions">
            <a class="inline-link" href="/request-a-quote?category=mammut-jacks&product=91000">Quote this model</a>
            <a class="inline-link" href="/mammut-jacks/91000-3-stage-high-tonnage-air-hydraulic-jack">View details</a>
          </div>
        </div>
      </div>
      <div class="path-card product-card">
        <img class="product-card-image" src="/images/products/12594.jpg" alt="ESCO Wheel Chock 12594" />
        <div class="product-card-body">
          <p class="eyebrow">Featured Product</p>
          <h3>Wheel Chock 12594</h3>
          <p>120 ton GVW-rated polyurethane wheel chock for larger heavy-equipment applications and demanding holding conditions.</p>
          <div class="product-actions">
            <a class="inline-link" href="/request-a-quote?category=wheel-chocks&product=12594">Quote this model</a>
            <a class="inline-link" href="/wheel-chocks/12594">View details</a>
          </div>
        </div>
      </div>
      <div class="path-card product-card">
        <img class="product-card-image" src="/images/products/12531.jpg" alt="CriBLOK Medium Kit 12531" />
        <div class="product-card-body">
          <p class="eyebrow">Featured Product</p>
          <h3>CriBLOK Medium Kit 12531</h3>
          <p>100 ton cribbing system kit with a practical mid-range build height for structured support setups.</p>
          <div class="product-actions">
            <a class="inline-link" href="/request-a-quote?category=cribbing&product=12531">Quote this family</a>
            <a class="inline-link" href="/cribbing/12531">View details</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="cta-band">
      <div>
        <h2>Already building a quote?</h2>
        <p class="lead">Use the quote list as you browse categories and detail pages, then review everything in one cleaner RFQ before sending.</p>
      </div>
      <div class="actions">
        <a class="btn btn-primary" href="/request-a-quote">Open Quote List</a>
        <a class="btn btn-secondary" href="/mammut-jacks">Browse Mammut</a>
      </div>
    </div>
  </section>

  <section class="section split">
    <div class="band-soft">
      <h2>Who We Serve</h2>
      <ul class="spec-list">
        <li>Heavy-duty repair shops</li>
        <li>Commercial fleets</li>
        <li>Mining and oilfield operations</li>
        <li>Municipal and public works departments</li>
        <li>Industrial contractors and maintenance teams</li>
      </ul>
    </div>
    <div class="band-soft">
      <h2>How the Quote Process Works</h2>
      <ol class="number-list">
        <li>Choose the category or product closest to the need</li>
        <li>Send the job details, model, or application requirements</li>
        <li>Get follow-up on fit, availability, and next steps</li>
      </ol>
      <div class="actions">
        <a class="btn btn-primary" href="/request-a-quote">Request a Quote</a>
      </div>
    </div>
  </section>
</Layout>
